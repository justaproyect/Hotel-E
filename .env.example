# ===========================================
# HERMES AGENT - Configuración
# ===========================================

# --- Servidor ---
PORT=3000
NODE_ENV=production

# --- Base de Datos ---
DATABASE_URL=postgresql://user:password@host:5432/hermes

# --- Redis (Colas) ---
REDIS_URL=redis://user:password@host:6379

# --- JWT (Admin Auth) ---
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=7d

# --- Ollama (AI Local/Nube) ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
# Modelo recomendado para agente: llama3.2, mistral, o llama3.2:70b

# --- Facebook Graph API ---
FB_APP_ID=your-fb-app-id
FB_APP_SECRET=your-fb-app-secret
FB_ACCESS_TOKEN=your-page-access-token
FB_PAGE_ID=your-facebook-page-id
FB_MARKETPLACE_CATEGORY_ID=your-category-id

# --- Instagram ---
IG_BUSINESS_ACCOUNT_ID=your-instagram-business-id
IG_ACCESS_TOKEN=your-ig-access-token

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Hotel Config ---
HOTEL_NAME=Hotel Hermes
HOTEL_ADDRESS=Calle Principal #123
HOTEL_PHONE=+521234567890
HOTEL_EMAIL=info@hotelhermes.com
HOTEL_CURRENCY=MXN
HOTEL_TIMEZONE=America/Mexico_City
